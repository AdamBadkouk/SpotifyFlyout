<Page x:Class="SpotifyFlyoutWPF.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="800"
      Title="AboutPage"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      d:Background="White">

    <StackPanel Margin="16">
            
            <!-- App Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Image Source="/Resources/SpotifyFlyout.ico" Width="64" Height="64" VerticalAlignment="Center" />
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="SpotifyFlyout" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="A modern Spotify controller for Windows" FontSize="14" Opacity="0.7" Margin="0,4,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- Section 1: About SpotifyFlyout -->
            <ui:CardExpander Icon="{ui:SymbolIcon Info24}" IsExpanded="False" Margin="0,0,0,8">
                <ui:CardExpander.Header>
                    <TextBlock Text="About SpotifyFlyout" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                </ui:CardExpander.Header>
                <StackPanel Margin="8">
                    <TextBlock TextWrapping="Wrap" FontSize="14" Opacity="0.85" Margin="0,0,0,16">
                        A lightweight, modern Windows 11 taskbar media controller designed for Spotify.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="GitHub Repository" Icon="{ui:SymbolIcon Open24}" Click="GitHubButton_Click" Margin="0,0,8,0" />
                        <ui:Button Content="Report a Bug" Icon="{ui:SymbolIcon Bug24}" Appearance="Secondary" Click="ReportBugButton_Click" />
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>

            <!-- Section 2: About FluentFlyout -->
            <ui:CardExpander Icon="{ui:SymbolIcon Heart24}" IsExpanded="False" Margin="0,0,0,8">
                <ui:CardExpander.Header>
                    <TextBlock Text="About FluentFlyout" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                </ui:CardExpander.Header>
                <StackPanel Margin="8">
                    <TextBlock TextWrapping="Wrap" FontSize="14" Opacity="0.85" Margin="0,0,0,12">
                        SpotifyFlyout is a modified, stripped-down fork of the open-source app FluentFlyout. 
                        We extend our gratitude to all the original contributors who made this possible.
                    </TextBlock>
                    <StackPanel Margin="0,0,0,16">
                        <ui:HyperlinkButton Content="View FluentFlyout on GitHub" 
                                            Icon="{ui:SymbolIcon Open24}" 
                                            NavigateUri="https://github.com/unchihugo/FluentFlyout" 
                                            Margin="0,0,0,4" />
                        <ui:HyperlinkButton Content="Sponsor on GitHub" 
                                            Icon="{ui:SymbolIcon Heart24}" 
                                            NavigateUri="https://github.com/sponsors/unchihugo" 
                                            Margin="0,0,0,4" />
                        <ui:HyperlinkButton Content="Support on Ko-fi" 
                                            Icon="{ui:SymbolIcon FoodCake24}" 
                                            NavigateUri="https://ko-fi.com/unchihugo" />
                    </StackPanel>
                    <TextBlock Text="Developers:" FontSize="13" FontWeight="SemiBold" Opacity="0.9" Margin="0,0,0,6" />
                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.7">
                        unchihugo, LiAuTraver, kitUIN, DmitriySalnikov, AksharDP, nopeless, xsm2, Simnico99, neegool, mak7im01, Hikaru11747
                    </TextBlock>
                </StackPanel>
            </ui:CardExpander>

            <!-- Section 3: Open Source Licenses -->
            <ui:CardExpander Icon="{ui:SymbolIcon Document24}" IsExpanded="False" Margin="0,0,0,8">
                <ui:CardExpander.Header>
                    <TextBlock Text="Open Source Licenses" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                </ui:CardExpander.Header>
                <StackPanel Margin="4">
                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.7" Margin="4,0,4,12">
                        SpotifyFlyout is built with the following open source packages:
                    </TextBlock>
                    
                    <ui:Card Margin="4,0,4,6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="CommunityToolkit.Mvvm" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="MIT License" FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:Card>
                    
                    <ui:Card Margin="4,0,4,6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Dubya.WindowsMediaController" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="MIT License" FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:Card>
                    
                    <ui:Card Margin="4,0,4,6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="MicaWPF" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="MIT License" FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:Card>
                    
                    <ui:Card Margin="4,0,4,6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Microsoft.Toolkit.Uwp.Notifications" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="MIT License" FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:Card>
                    
                    <ui:Card Margin="4,0,4,6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="NAudio" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="MIT License" FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:Card>
                    
                    <ui:Card Margin="4,0,4,6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="NLog" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="BSD 3-Clause License" FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:Card>
                    
                    <ui:Card Margin="4,0,4,6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="WPF-UI" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="MIT License" FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:Card>
                    
                    <ui:Card Margin="4,0,4,4" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="WPF-UI.Tray" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="MIT License" FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ui:CardExpander>

    </StackPanel>
</Page>